# ── Node / Next.js ────────────────────────────────────────────────
app/node_modules/
app/.next/
app/out/
app/build/
app/*.tsbuildinfo
app/next-env.d.ts
app/.turbo/
app/.vercel/

# ── Cloudflare / OpenNext ─────────────────────────────────────────
app/.open-next/
app/.wrangler/
app/.dev.vars
app/cloudflare-env.d.ts

# ── Sensitive runtime data — NEVER commit ─────────────────────────
# SQLite databases (contain encrypted page tokens, accounts, fanpages)
app/data/

# Playwright / browser profiles (cookies, session, credentials)
**/ms-profiles/

# TikTok web embed snapshot
app/probe-state.json

# Environment files
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── OS / editor ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
.claude/
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────
*.pem
.cache/
coverage/
